{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    { "title": "Overview", "url": "/d/vcenter-overview", "type": "dashboard", "asDropdown": true },
    { "title": "Hosts", "url": "/d/vcenter-hosts", "type": "dashboard", "asDropdown": false },
    { "title": "Host Performance", "url": "/d/vcenter-host-performance", "type": "dashboard", "asDropdown": false },
    { "title": "VM Metrics", "url": "/d/vcenter-vm-metrics", "type": "dashboard", "asDropdown": false },
    { "title": "VM Performance", "url": "/d/vcenter-vm-performance", "type": "dashboard", "asDropdown": false }
  ],
  "liveNow": false,
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 3, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "content": "## Host: **${host}**\n\nAll collected performance metrics for the selected host. Use the **Host** dropdown above to switch hosts.",
        "mode": "markdown"
      },
      "title": "Selected host",
      "type": "text"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "displayMode": "auto" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Value" }, "properties": [{ "id": "unit", "value": "short" }, { "id": "decimals", "value": 4 }] }
        ]
      },
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 3 },
      "id": 2,
      "options": { "showHeader": true, "cellHeight": "sm", "footer": { "show": true, "reducer": ["sum"], "countRows": true } },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "vcenter_perf_value{app=~\"$app\", vcenter=~\"$vcenter\", resource_type=\"HOST\", resource_name=\"$host\"}",
        "format": "table",
        "instant": true,
        "refId": "A"
      }],
      "title": "All metrics (latest values)",
      "transformations": [
        { "id": "merge", "options": {} },
        { "id": "organize", "options": { "excludeByName": { "Time": true, "job": true, "instance": true, "app": true, "vcenter": true, "resource_type": true, "resource_name": true }, "renameByName": { "metric": "Metric", "Value": "Value" } } }
      ],
      "type": "table"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 17 },
      "id": 3,
      "options": { "legend": { "displayMode": "table", "placement": "right", "showLegend": true } },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "vcenter_perf_value{app=~\"$app\", vcenter=~\"$vcenter\", resource_type=\"HOST\", resource_name=\"$host\"}",
        "legendFormat": "{{ metric }}",
        "refId": "A"
      }],
      "title": "All metrics over time",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 36,
  "style": "dark",
  "tags": ["vcenter", "hosts", "metrics"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" },
        "hide": 0,
        "includeAll": false,
        "label": "Data source",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "skipUrlSync": false,
        "type": "datasource",
        "datasource": { "type": "prometheus", "uid": "prometheus" }
      },
      {
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "hide": 0,
        "includeAll": true,
        "label": "vCenter",
        "multi": true,
        "name": "vcenter",
        "options": [],
        "allValue": ".*",
        "query": "label_values(vcenter_perf_value{resource_type=\"HOST\"}, vcenter)",
        "refresh": 2,
        "skipUrlSync": false,
        "type": "query"
      },
      {
        "current": { "selected": false, "text": "All", "value": ".*" },
        "hide": 0,
        "includeAll": true,
        "label": "App",
        "multi": true,
        "name": "app",
        "options": [],
        "allValue": ".*",
        "query": "label_values(vcenter_perf_value{resource_type=\"HOST\", vcenter=~\"$vcenter\"}, app)",
        "refresh": 2,
        "skipUrlSync": false,
        "type": "query"
      },
      {
        "current": { "selected": false, "text": "", "value": "" },
        "hide": 0,
        "includeAll": false,
        "label": "Host",
        "multi": false,
        "name": "host",
        "options": [],
        "query": "label_values(vcenter_perf_value{app=~\"$app\", vcenter=~\"$vcenter\", resource_type=\"HOST\"}, resource_name)",
        "refresh": 2,
        "skipUrlSync": false,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "vCenter Host Metrics (all)",
  "uid": "vcenter-host-metrics",
  "version": 1,
  "weekStart": ""
}
