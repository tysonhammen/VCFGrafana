        "expr": "vcenter_datastore_free_bytes{app=~\"$app\", vcenter=~\"$vcenter\", name=~\"$datastore\"} / vcenter_datastore_capacity_bytes{app=~\"$app\", vcenter=~\"$vcenter\", name=~\"$datastore\"} * 100",
        "format": "table",
        "instant": true,
        "legendFormat": "{{ name }}",
        "refId": "A"
      }],
      "title": "Datastore free space %",
      "transformations": [
        { "id": "merge", "options": {} },
        { "id": "organize", "options": { "excludeByName": { "Time": true }, "renameByName": { "Value": "Free %", "name": "Datastore", "vcenter": "vCenter" } } }
