      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "sum(vcenter_datastore_free_bytes{app=~\"$app\", vcenter=~\"$vcenter\"}) / sum(vcenter_datastore_capacity_bytes{app=~\"$app\", vcenter=~\"$vcenter\"}) * 100",
