{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    { "title": "Overview", "url": "/d/vcenter-overview", "type": "dashboard", "asDropdown": true },
    { "title": "Clusters", "url": "/d/vcenter-clusters", "type": "dashboard", "asDropdown": false },
    { "title": "Hosts", "url": "/d/vcenter-hosts", "type": "dashboard", "asDropdown": false },
    { "title": "Host Performance", "url": "/d/vcenter-host-performance", "type": "dashboard", "asDropdown": false },
    { "title": "VMs", "url": "/d/vcenter-vms", "type": "dashboard", "asDropdown": false },
    { "title": "VM Performance", "url": "/d/vcenter-vm-performance", "type": "dashboard", "asDropdown": false },
    { "title": "Storage", "url": "/d/vcenter-storage", "type": "dashboard", "asDropdown": false },
    { "title": "vSAN Health", "url": "/d/vcenter-vsan", "type": "dashboard", "asDropdown": false }
  ],
  "liveNow": false,
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 50 }, { "color": "green", "value": 80 }] },
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "options": { "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "vcenter_vsan_cluster_health_score{vcenter=~\"$vcenter\", cluster_name=~\"$cluster\"}",
        "legendFormat": "{{ cluster_name }}",
        "refId": "A",
        "instant": true
      }],
      "title": "vSAN cluster health score",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 6, "y": 0 },
      "id": 2,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "vcenter_vsan_cluster_health_score{vcenter=~\"$vcenter\", cluster_name=~\"$cluster\"}",
        "legendFormat": "{{ cluster_name }}",
        "refId": "A"
      }],
      "title": "vSAN cluster health score over time",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "1": { "color": "green", "index": 0, "text": "Green" } }, "type": "value" },
            { "options": { "0.5": { "color": "yellow", "index": 0, "text": "Yellow" } }, "type": "value" },
            { "options": { "0": { "color": "red", "index": 0, "text": "Red/Gray" } }, "type": "value" }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "id": 3,
      "options": { "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "sum(vcenter_vsan_host_health_status{vcenter=~\"$vcenter\", cluster_name=~\"$cluster\", status=\"green\"}) or vector(0)",
        "legendFormat": "Green",
        "refId": "A",
        "instant": true
      }, {
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "sum(vcenter_vsan_host_health_status{vcenter=~\"$vcenter\", cluster_name=~\"$cluster\", status=\"yellow\"}) or vector(0)",
        "legendFormat": "Yellow",
        "refId": "B",
        "instant": true
      }, {
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "sum(vcenter_vsan_host_health_status{vcenter=~\"$vcenter\", cluster_name=~\"$cluster\", status=~\"red|gray\"}) or vector(0)",
        "legendFormat": "Red/Gray",
        "refId": "C",
        "instant": true
      }],
      "title": "Hosts by status (current)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 8 },
      "id": 4,
      "options": { "showHeader": true, "cellHeight": "sm" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "vcenter_vsan_cluster_health_score{vcenter=~\"$vcenter\", cluster_name=~\"$cluster\"}",
        "format": "table",
        "instant": true,
        "refId": "A"
      }],
      "title": "vSAN cluster health",
      "transformations": [
        { "id": "merge", "options": {} },
        { "id": "organize", "options": { "excludeByName": { "Time": true }, "renameByName": { "vcenter": "vCenter", "cluster_id": "Cluster ID", "cluster_name": "Cluster", "Value": "Health score" } } }
      ],
      "type": "table"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "align": "auto" },
          "mappings": [
            { "options": { "1": { "color": "green", "index": 0, "text": "Green" } }, "type": "value" },
            { "options": { "0.5": { "color": "yellow", "index": 0, "text": "Yellow" } }, "type": "value" },
            { "options": { "0": { "color": "red", "index": 0, "text": "Red/Gray" } }, "type": "value" }
          ]
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Value" }, "properties": [{ "id": "custom.cellOptions", "value": { "type": "color-background" } }] },
          { "matcher": { "id": "byName", "options": "Host" }, "properties": [{ "id": "links", "value": [{ "title": "View host performance", "url": "/d/vcenter-host-performance?var-host=${__value.raw}" }] }] }
        ]
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 18 },
      "id": 5,
      "options": { "showHeader": true, "cellHeight": "sm" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "vcenter_vsan_host_health_status{vcenter=~\"$vcenter\", cluster_name=~\"$cluster\"}",
        "format": "table",
        "instant": true,
        "refId": "A"
      }],
      "title": "vSAN host health status",
      "transformations": [
        { "id": "merge", "options": {} },
        { "id": "organize", "options": { "excludeByName": { "Time": true }, "renameByName": { "vcenter": "vCenter", "cluster_name": "Cluster", "host": "Host", "status": "Status", "Value": "Status value" } } }
      ],
      "type": "table"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 36,
  "style": "dark",
  "tags": ["vcenter", "vsan", "health"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" },
        "hide": 0,
        "includeAll": false,
        "label": "Data source",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "skipUrlSync": false,
        "type": "datasource",
        "datasource": { "type": "prometheus", "uid": "prometheus" }
      },
      {
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "hide": 0,
        "includeAll": true,
        "label": "vCenter",
        "multi": true,
        "name": "vcenter",
        "options": [],
        "allValue": ".*",
        "query": "label_values(vcenter_vsan_cluster_health_score, vcenter)",
        "refresh": 2,
        "skipUrlSync": false,
        "type": "query"
      },
      {
        "current": { "selected": false, "text": "All", "value": ".*" },
        "hide": 0,
        "includeAll": true,
        "label": "Cluster",
        "multi": true,
        "name": "cluster",
        "options": [],
        "allValue": ".*",
        "query": "label_values(vcenter_vsan_cluster_health_score{vcenter=~\"$vcenter\"}, cluster_name)",
        "refresh": 2,
        "skipUrlSync": false,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "vCenter vSAN Health",
  "uid": "vcenter-vsan",
  "version": 1,
  "weekStart": ""
}
