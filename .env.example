# vCenter connection (required)
VCENTER_SERVER=https://vcenter.example.com
VCENTER_USER=administrator@vsphere.local
VCENTER_PASSWORD=your_password

# Optional: set to false to skip SSL verification (e.g. self-signed certs)
VCENTER_VERIFY_SSL=true

# Exporter listen address and port
EXPORTER_HOST=0.0.0.0
EXPORTER_PORT=9680

# Scrape interval hint (seconds) - how often to refresh vCenter data
SCRAPE_INTERVAL=300

# Optional: log to file and set level (DEBUG to troubleshoot performance/vStats)
# LOG_FILE=/var/log/vcenter-exporter.log
# LOG_LEVEL=DEBUG

# Performance collection (can cause long scrapes / Prometheus timeout)
# VCENTER_COLLECT_PERF=true   # set false/0 to disable host/VM perf (inventory only)
# VCENTER_PERF_TIMEOUT_SEC=0  # stop perf after N seconds (0 = no limit)
# VCENTER_PERF_MAX_HOSTS=0    # cap hosts for perf (0 = no limit)
# VCENTER_PERF_MAX_VMS=0      # cap VMs for perf (0 = no limit)
# VCENTER_PERF_ASYNC=false   # true = collect perf in background, serve from cache (avoids scrape timeout)
# VCENTER_PERF_INTERVAL_SEC=300  # when async, refresh cache every N seconds
