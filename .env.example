# vCenter connection (required)
VCENTER_SERVER=https://vcenter.example.com
VCENTER_USER=administrator@vsphere.local
VCENTER_PASSWORD=your_password

# Optional: set to false to skip SSL verification (e.g. self-signed certs)
VCENTER_VERIFY_SSL=true

# Exporter listen address and port
EXPORTER_HOST=0.0.0.0
EXPORTER_PORT=9680

# Scrape interval hint (seconds) - how often to refresh vCenter data
SCRAPE_INTERVAL=300

# Optional: log to file and set level (DEBUG to troubleshoot performance/vStats)
# LOG_FILE=/var/log/vcenter-exporter.log
# LOG_LEVEL=DEBUG
